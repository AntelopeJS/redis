{
  "name": "@antelopejs/redis",
  "version": "1.0.1",
  "description": "Redis module that implements the redis interface of antelopejs",
  "keywords": [
    "antelopejs",
    "redis",
    "cache",
    "key-value",
    "nosql"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/redis.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "ajs project run -w -p playground --inspect",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "pnpm run build && ajs module test ."
  },
  "antelopeJs": {
    "implements": [
      "@antelopejs/interface-redis",
      "@antelopejs/interface-redis-scheduler"
    ],
    "defaultConfig": {
      "url": "redis://localhost:6379"
    },
    "test": "src/test/antelope.test.ts"
  },
  "dependencies": {
    "@antelopejs/interface-core": "^0.0.2",
    "@antelopejs/interface-redis": "^0.0.2",
    "@antelopejs/interface-redis-scheduler": "^0.0.2",
    "ioredis": "^5.10.1",
    "ioredis-mock": "^8.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/chai": "^4.3.20",
    "@types/ioredis-mock": "^8.2.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "chai": "^4.5.0",
    "release-it": "^19.2.4",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
